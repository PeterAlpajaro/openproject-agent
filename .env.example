# OpenProject API token (generated from your OpenProject admin panel)
OPENPROJECT_API_TOKEN=your_openproject_api_token_here

# Kiro Gateway / Anthropic proxy key (orchestrator uses this to auth with gateway)
ANTHROPIC_API_KEY=my_local_dev_key

# Your AWS Profile ARN (find it in: ~/Library/Application Support/Kiro/User/globalStorage/kiro.kiroagent/profile.json)
PROFILE_ARN=arn:aws:codewhisperer:us-east-1:YOUR_ACCOUNT_ID:profile/YOUR_PROFILE_ID

# Claude model (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenProject secret (optional, defaults to 'secret')
OPENPROJECT_SECRET_KEY_BASE=secret
